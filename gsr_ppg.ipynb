import time
import requests
import json
from serial import Serial
from pyshimmer import ShimmerBluetooth, DataPacket, EChannelType

# Formula to convert raw shimmer signal to meaningful GSR values (Ohm)
rf_values = {0: 40200.0, 1: 287000.0, 2: 1000000.0, 3: 3300000.0}

# URL of the server endpoint for PPG data (physiological data)
SERVER_URL_PPG = "http://localhost:5000/upload-gsr"

# Local buffer for shimmer data (we now care only about ppg)
shimmer_data_buffer = []

def send_shimmer_chunk():
    global shimmer_data_buffer
    if not shimmer_data_buffer:
        return
    try:
        response = requests.post(SERVER_URL_PPG, json=shimmer_data_buffer)
        print(f"Sent {len(shimmer_data_buffer)} samples. Server responded: {response.text}")
    except Exception as e:
        print(f"Error sending shimmer chunk: {e}")
    # Clear the buffer after sending
    shimmer_data_buffer = []

def handler(pkt: DataPacket) -> None:
    # Retrieve raw GSR signal (if needed) and ppg
    # (We will ignore gsr for sending to the server)
    ppg = pkt[EChannelType.INTERNAL_ADC_13]
    timestamp = time.time()
    # Convert raw GSR to Ohms (based on Shimmer GSR calibration)
    try:
        # Assume range setting is known (e.g., 0 for 10-47 kOhm range)
        range_setting = 0  # Adjust based on your Shimmer configuration
        rf = rf_values.get(range_setting, 40200.0)
        # GSR formula: Resistance (Ohms) = Rf * ((65536 / raw_gsr) - 1)
        if raw_gsr > 0:
            gsr_ohms = rf * ((65536 / raw_gsr) - 1)
        else:
            gsr_ohms = None
            print("Warning: Invalid raw GSR value, setting GSR to None")
    except Exception as e:
        print(f"Error converting GSR: {e}")
        gsr_ohms = None
    # Build sample dict with only the keys needed by your server
    sample = {
        "timestamp": timestamp,
        "gsr": gsr_ohms,
        "ppg": ppg
    }
    # Append the sample to the local buffer
    shimmer_data_buffer.append(sample)
    print(f"Buffered new sample: {sample}")

if __name__ == '__main__':
    from pyshimmer import ShimmerBluetooth
    # Connect to the device
    serial = Serial('COM10', 9600)
    shim_dev = ShimmerBluetooth(serial)
    shim_dev.initialize()
   
    dev_name = shim_dev.get_device_name()
    print(f"My device name: {dev_name}")
   
    # Register the callback
    shim_dev.add_stream_callback(handler)
    shim_dev.start_streaming()
   
    last_send_time = time.time()
   
    try:
        while True:
            time.sleep(1)
            current_time = time.time()
            # Send the buffered data every 10 seconds
            if current_time - last_send_time >= 10:
                send_shimmer_chunk()
                last_send_time = current_time
            print("Working...")
    except KeyboardInterrupt:
        print("Shutdown signal received. Stopping stream...")
        shim_dev.stop_streaming()
        send_shimmer_chunk()  # Send any remaining data
        print("Shutdown complete.")

